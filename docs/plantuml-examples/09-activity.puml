@startuml
' ============================================================
' Example 9: Action/Activity Diagram
' Shows actions, control flows, and decision nodes using
' PlantUML's activity syntax.
' ============================================================

<style>
root {
    BackGroundColor white
    FontName Helvetica
    FontSize 13
}
activity {
    BackgroundColor #EBF5FB
    LineColor #3498DB
    LineThickness 1.5
    RoundCorner 10
    Padding 8
}
activityStart {
    BackgroundColor #27AE60
}
activityStop {
    BackgroundColor #E74C3C
}
activityDiamond {
    BackgroundColor #FDEBD0
    LineColor #E67E22
}
arrow {
    LineColor #34495E
    LineThickness 1.5
    FontSize 11
}
</style>

skinparam wrapWidth 400

title SysML v2 — Activity: Vehicle Start Sequence

start

:Initialize ECU;
note right
  Load calibration data
  and run self-diagnostics
end note

:Check Battery Voltage;

if (Voltage > 12V?) then (yes)
  :Engage Starter Motor;

  if (Engine Cranking?) then (yes)
    :Inject Fuel;
    :Ignite Spark;

    if (Engine Running?) then (yes)
      :Disengage Starter;
      :Transition to Idle;
      note right
        ECU monitors idle
        speed and adjusts
        air/fuel ratio
      end note
      stop
    else (no)
      :Increment Retry Count;
      if (Retry Count < 3?) then (yes)
        :Re-attempt Start;
        :Engage Starter Motor;
      else (no)
        :Report Start Failure;
        stop
      endif
    endif
  else (no)
    :Report Crank Failure;
    stop
  endif
else (no)
  :Report Low Battery;
  :Request Jump Start;
  stop
endif

@enduml
