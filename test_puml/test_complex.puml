@startuml

<style>
root {
    BackGroundColor white
    FontName Helvetica
    FontSize 13
}
rectangle {
    RoundCorner 15
    LineColor #444444
    LineThickness 1.5
    BackgroundColor white
    Padding 10
}
arrow {
    LineColor #555555
    LineThickness 1.5
    FontSize 11
}
</style>

skinparam wrapWidth 400

top to bottom direction

title cfe16e67-1e95-46ad-a08a-b7362f869b92

hide circle

rectangle "RotatingPart" as E1 <<(P,#32CD32) part def>>
rectangle "Wheel" as E2 <<(P,#32CD32) part def>>
rectangle "radius" as E3 <<(A,#32CD32) attribute>>
rectangle "mass" as E4 <<(A,#32CD32) attribute>>
rectangle "CarWheel" as E5 <<(P,#32CD32) part def>>
rectangle "8993b758-2153-4de9-bc03-57d0041f7087" as E6 <<(A,#32CD32) attribute>>
rectangle "tirePressure" as E7 <<(A,#32CD32) attribute>>
rectangle "Axle" as E8 <<(P,#32CD32) part def>>
rectangle "Vehicle" as E9 <<(P,#32CD32) part def>>
rectangle "frontLeft" as E10 <<(P,#32CD32) part>>
rectangle "frontRight" as E11 <<(P,#32CD32) part>>
rectangle "rearAxle" as E12 <<(P,#32CD32) part>>

E2 --|> E1 : specializes
E2 *-- E3
E2 *-- E4
E5 --|> E2 : specializes
E5 *-- E6
E6 --||> E3 : redefines
E5 *-- E7
E9 *-- E10
E10 --:|> E5 : types
E9 *-- E11
E11 --:|> E5 : types
E9 *-- E12
E12 --:|> E8 : types

legend right
  <b>SysML v2 Relationship Legend</b>
  |= Relationship |= Notation |
  | Feature Typing | --:|> |
  | Specialization | --|> |
  | Redefinition | --||> |
  | Composite (owns) | *-- |
  | Shared | o-- |
  | Binding | -[thickness=4]- |
  | Connector | -[thickness=2]-> |
  | Flow | --> |
  | Dependency | ..>> |
endlegend

@enduml