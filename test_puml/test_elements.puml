@startuml

<style>
root {
    BackGroundColor white
    FontName Helvetica
    FontSize 13
}
rectangle {
    RoundCorner 15
    LineColor #444444
    LineThickness 1.5
    BackgroundColor white
    Padding 10
}
arrow {
    LineColor #555555
    LineThickness 1.5
    FontSize 11
}
</style>

skinparam wrapWidth 400

top to bottom direction

title SysML v2 — Selected Elements (3)

hide circle

rectangle "Wheel" as E1 <<(P,#32CD32) part def>>
rectangle "CarWheel" as E3 <<(P,#32CD32) part def>>
rectangle "Vehicle" as E4 <<(P,#32CD32) part def>>

E3 --|> E1 : specializes

legend right
  <b>SysML v2 Relationship Legend</b>
  |= Relationship |= Notation |
  | Feature Typing | --:|> |
  | Specialization | --|> |
  | Redefinition | --||> |
  | Composite (owns) | *-- |
  | Shared | o-- |
  | Binding | -[thickness=4]- |
  | Connector | -[thickness=2]-> |
  | Flow | --> |
  | Dependency | ..>> |
endlegend

@enduml